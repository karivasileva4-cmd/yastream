{
  "name": "yastream",
  "version": "0.7.3",
  "description": "Yet Another Stream. Stream asian dramas, series and movies directly with multiple providers. Support catalogs with country selection. Powered by TMDB and TVDB for metadata",
  "scripts": {
    "start": "node --env-file=.env dist/server.js",
    "build": "tsc",
    "dev": "tsc && node --trace-warnings --env-file=.env dist/server.js",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate"
  },
  "type": "module",
  "engines": {
    "node": "^22.0.0 || ^24.0.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@stremio-addon/sdk": "github:hoangtamthai/stremio-addon-sdk#sdk",
    "@umami/node": "^0.4.0",
    "axios": "^1.15.2",
    "axios-rate-limit": "^1.9.0",
    "better-sqlite3": "^12.9.0",
    "cheerio": "^1.2.0",
    "crypto-js": "^4.2.0",
    "drizzle-orm": "^0.45.2",
    "fuse.js": "^7.3.0",
    "fuzzball": "^2.2.3",
    "hono": "^4.12.15",
    "hono-rate-limiter": "^0.5.3",
    "hono-tailwind": "^3.0.1",
    "tailwindcss": "^4.2.4",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/probe-image-size": "^7.2.5",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
