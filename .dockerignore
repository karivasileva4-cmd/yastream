# Dockerignore for yastream
# Exclude development dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Exclude test files
tests/
coverage/
.nyc_output

# Exclude source control
.git/
.gitignore
.gitattributes

# Exclude development files
.env.local
.env.*.local

# Exclude IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Exclude OS files
.DS_Store
Thumbs.db

# Exclude logs
logs/
*.log

# Exclude runtime data
tmp/
pids/
*.pid
*.seed
*.pid.lock

# Exclude documentation
README.md
# CHANGELOG.md # need this for showing on landing page
LICENSE

# Exclude Docker files
Dockerfile*
docker-compose*
.dockerignore

# Exclude other config files
babel.config.js
jest.config.js
.prettierrc*
.eslintrc*

data